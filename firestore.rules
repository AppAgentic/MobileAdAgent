rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberPath(orgId) {
      return /databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid);
    }

    function isOrgMember(orgId) {
      return signedIn() && exists(memberPath(orgId));
    }

    function memberRole(orgId) {
      return get(memberPath(orgId)).data.role;
    }

    function hasOrgRole(orgId, roles) {
      return isOrgMember(orgId) && memberRole(orgId) in roles;
    }

    function userCreateShape(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'orgId',
          'workspaceId',
          'createdAt',
          'updatedAt',
          'providerMutations'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.orgId is string
        && request.resource.data.workspaceId is string
        && (!('providerMutations' in request.resource.data) || request.resource.data.providerMutations == 0);
    }

    function userUpdateShape(uid) {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.uid == uid
        && request.resource.data.orgId == resource.data.orgId
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'photoURL',
          'updatedAt'
        ]);
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid) && userCreateShape(uid);
      allow update: if isSelf(uid) && userUpdateShape(uid);
      allow delete: if false;
    }

    match /orgs/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create, update, delete: if false;

      match /members/{uid} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if false;
      }

      match /invites/{inviteId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin']);
        allow create, update, delete: if false;
      }

      match /workspaces/{workspaceId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if false;

        match /apps/{appId} {
          allow read: if isOrgMember(orgId);
          allow create, update, delete: if false;

          match /appProfiles/{profileId} {
            allow read: if isOrgMember(orgId);
            allow create, update, delete: if false;
          }

          match /sourceAssets/{assetId} {
            allow read: if isOrgMember(orgId);
            allow create, update, delete: if false;
          }

          match /researchSnapshots/{snapshotId} {
            allow read: if isOrgMember(orgId);
            allow create, update, delete: if false;
          }

          match /packPlans/{planId} {
            allow read: if isOrgMember(orgId);
            allow create, update, delete: if false;
          }

          match /packPlanRequests/{requestId} {
            allow read, write: if false;
          }

          match /creativePacks/{packId} {
            allow read: if isOrgMember(orgId);
            allow create, update, delete: if false;

            match /generatedCreatives/{creativeId} {
              allow read: if isOrgMember(orgId);
              allow create, update, delete: if false;
            }

            match /reviewDecisions/{decisionId} {
              allow read: if isOrgMember(orgId);
              allow create, update, delete: if false;
            }

            match /exports/{exportId} {
              allow read: if isOrgMember(orgId);
              allow create, update, delete: if false;
            }
          }

          match /creativeJobs/{jobId} {
            allow read: if isOrgMember(orgId);
            allow create, update, delete: if false;
          }

          match /learningEvents/{eventId} {
            allow read: if isOrgMember(orgId);
            allow create, update, delete: if false;
          }
        }
      }

      match /creditLedger/{txnId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'billing']);
        allow create, update, delete: if false;
      }

      match /entitlements/{entitlementId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'billing']);
        allow create, update, delete: if false;
      }

      match /claims/{claimId} {
        allow read, write: if false;
      }

      match /apiKeys/{apiKeyId} {
        allow read, write: if false;
      }

      match /auditEvents/{eventId} {
        allow read, write: if false;
      }
    }

    match /previewCache/{canonicalAppId} {
      allow read, write: if false;
    }

    match /previewSessions/{sessionId} {
      allow read, write: if false;
    }

    match /renderTasks/{taskId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
